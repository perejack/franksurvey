# Environment Variables for Production

# Hashback M-Pesa API Configuration
# Get these from https://hashback.co.ke dashboard
VITE_HASHBACK_API_KEY=your_api_key_here
VITE_HASHBACK_ACCOUNT_ID=your_account_id_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Note: In production, API credentials should be stored in Vercel Environment Variables
# Go to Project Settings > Environment Variables in Vercel dashboard
# Add the above variables for Production environment
